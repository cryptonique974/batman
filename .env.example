ASSISTANT_HAS_OWN_NUMBER=  # true if bot uses a dedicated number or linked device (fromMe is reliable); false if shared number with manual prefix
WHISPER_BIN=whisper-cli     # path to whisper.cpp CLI binary (default: whisper-cli in PATH)
WHISPER_MODEL=              # path to ggml model file (default: data/models/ggml-base.bin)
VOICE_ENABLED=true          # enable STT/TTS voice support for WhatsApp voice notes
